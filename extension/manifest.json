{
  "manifest_version": 3,
  "name": "Bookmark Advisor Executor",
  "version": "0.1.1",
  "description": "Generate, review, and apply Bookmark Advisor plans with chrome.bookmarks APIs.",
  "minimum_chrome_version": "116",
  "permissions": ["bookmarks", "storage", "offscreen"],
  "host_permissions": [],
  "optional_host_permissions": ["https://*/*"],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Bookmark Advisor Executor"
  }
}
